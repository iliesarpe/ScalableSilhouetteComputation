bootstrap: docker
From: ubuntu:jammy-20230301

%files
  . /usr/src/silhouette

%post
  apt-get update && apt-get install -y --no-install-recommends \
    bzip2 ca-certificates curl g++ make libhdf5-dev && \
  rm -rf /var/lib/apt/lists/*

  # --- micromamba -----------------------------------------------------------
  curl -Ls https://micro.mamba.pm/api/micromamba/linux-64/latest \
    | tar -xvj -C /usr/local/bin --strip-components=1 bin/micromamba

  # Minimal Python environment (demo / library usage).
  # Full research-pipeline packages are in environment.yml; install those
  # separately with: micromamba env create -f cppCode/environment.yml
  MAMBA_ROOT_PREFIX=/opt/mamba micromamba create -y \
    -p /opt/silhenv \
    -c conda-forge \
    python=3.12 numpy scikit-learn matplotlib seaborn h5py

  # --- nlohmann/json single-header (not vendored in the repo) --------------
  mkdir -p /usr/local/include/nlohmann
  curl -fsSL \
    https://raw.githubusercontent.com/nlohmann/json/v3.11.3/single_include/nlohmann/json.hpp \
    -o /usr/local/include/nlohmann/json.hpp

  # --- C++ binary -----------------------------------------------------------
  # HighFive is vendored in cppCode/import/; only libhdf5-dev is needed from apt.
  cd /usr/src/silhouette/cppCode && make

%environment
  export PATH="/opt/silhenv/bin:$PATH"

%runscript
  /usr/src/silhouette/cppCode/efficientSilh "$@"
